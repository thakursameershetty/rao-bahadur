generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Theory {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  author    String
  tag       String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  comments  Comment[]
}

model Comment {
  id        String   @id @default(uuid())
  theoryId  String
  author    String
  text      String   @db.Text
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")

  theory    Theory   @relation(fields: [theoryId], references: [id], onDelete: Cascade)
}

model Character {
  id      String @id
  likes   Int    @default(0)
}

model GlobalStat {
  id    String @id @default("counter")
  count Int    @default(12438201)
}

model CelebrityVideo {
  id        String   @id @default(uuid())
  title     String
  src       String
  poster    String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

